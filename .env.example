# Kopieer dit bestand naar ".env" lokaal, of zet deze waarden als Environment Variables
# in je Vercel-project (Settings → Environment Variables). Commit .env NOOIT naar git.

# Te vinden in het Stripe Dashboard → Developers → API keys.
# Gebruik eerst de sk_test_... sleutel om te testen, pas later over naar sk_live_...
STRIPE_SECRET_KEY=sk_test_vervang_mij

# Te vinden in het Stripe Dashboard → Developers → Webhooks, nadat je de webhook-endpoint
# hebt aangemaakt (zie README.md).
STRIPE_WEBHOOK_SECRET=whsec_vervang_mij

# De volledige URL waarop de site straks live staat, zonder trailing slash.
# Lokaal testen: http://localhost:3000
SITE_URL=https://jouw-domein.vercel.app
